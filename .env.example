# GitHub Models (free with Copilot subscription)
GITHUB_TOKEN=your_github_token_here

# AI model to use (default: openai/gpt-4.1-mini)
AI_MODEL=openai/gpt-4.1-mini

# AI provider base URL (default: GitHub Models)
AI_BASE_URL=https://models.github.ai/inference

# Path to SQLite database (default: ./flouz.db)
DB_PATH=./flouz.db
